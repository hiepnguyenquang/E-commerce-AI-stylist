# Cấu hình AI Service (FastAPI)
PORT=8000
ENVIRONMENT="development"

# Đường dẫn thư mục lưu trữ Vector Database LanceDB
LANCEDB_URI="./data/lancedb"

# Kết nối RabbitMQ (để lắng nghe Job VTON và Data Sync)
RABBITMQ_URL="amqp://guest:guest@localhost:5672"

# Security (Phải giống với giá trị bên api-medusa)
INTERNAL_API_SECRET="your_super_secret_internal_key_here"

# Cấu hình LLM API (Dành cho tính năng AI Stylist/Extractor)
# Có thể dùng OpenAI, Kimi hoặc Gemini (sẽ cập nhật API Key thật vào .env.local)
OPENAI_API_KEY="sk-..."
