# Cơ sở dữ liệu (Database) từ Docker Compose
DATABASE_URL="postgres://medusa_admin:medusa_password@localhost:5432/medusa_db"

# Redis Cache
REDIS_URL="redis://localhost:6379"

# RabbitMQ Connection
RABBITMQ_URL="amqp://guest:guest@localhost:5672"

# AI Service
AI_SERVICE_URL="http://127.0.0.1:8000"

# Security (Internal API Auth)
INTERNAL_API_SECRET="your_super_secret_internal_key_here"

# Medusa Core config
JWT_SECRET="something_secret"
COOKIE_SECRET="something_secret"

# Vị trí frontend
STORE_CORS="http://localhost:3000"
ADMIN_CORS="http://localhost:7001"
AUTH_CORS="http://localhost:3000,http://localhost:9000"
